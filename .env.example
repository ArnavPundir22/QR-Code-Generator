# QR Code Generator – environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Flask secret key – generate a random value with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: http://localhost:5000/auth/google  (adjust for production)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# Create an OAuth App at https://github.com/settings/developers
# Authorised callback URL: http://localhost:5000/auth/github  (adjust for production)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
